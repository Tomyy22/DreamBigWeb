@inherits LayoutComponentBase
@using DreamBig.Web.Constants
@inject AuthService Auth
@inject NavigationManager Nav

@if (Auth.IsAuthenticated)
{
    <MudThemeProvider Theme="_theme" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <MudLayout>
        <MudAppBar Elevation="1" Style="@($"background-color: {ThemeColors.WillowGreen}; color: {ThemeColors.TextoGris};")">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
            <MudText Typo="Typo.h5" Class="ml-3">DREAM BIG ENGLISH TUITION</MudText>
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Style="@($"background-color: {ThemeColors.Bone};")">
            <MudDrawerHeader>
                <MudText Typo="Typo.h6" Style="@($"color: {ThemeColors.TextoGris};")">Menú</MudText>
            </MudDrawerHeader>
            <MudNavMenu>
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Menú Principal</MudNavLink>

                <MudNavGroup Title="Alumnos" Icon="@Icons.Material.Filled.Person">
                    <MudNavLink Href="/students/add">Agregar alumno</MudNavLink>
                    <MudNavLink Href="/students">Gestionar alumnos</MudNavLink>
                </MudNavGroup>

                <MudNavGroup Title="Clases" Icon="@Icons.Material.Filled.Class">
                    <MudNavLink Href="/classes/add">Crear clase</MudNavLink>
                    <MudNavLink Href="/classes/manage">Gestionar clases</MudNavLink>
                </MudNavGroup>

                <MudNavGroup Title="Tutores" Icon="@Icons.Material.Filled.SupervisorAccount">
                    <MudNavLink Href="/tutors/add">Agregar tutor</MudNavLink>
                    <MudNavLink Href="/tutors/manage">Gestionar tutores</MudNavLink>
                </MudNavGroup>

                <MudNavGroup Title="Profesores" Icon="@Icons.Material.Filled.School">
                    <MudNavLink Href="/teachers/add">Agregar profesor</MudNavLink>
                    <MudNavLink Href="/teachers/manage">Gestionar profesores</MudNavLink>
                </MudNavGroup>

                <MudNavLink Href="/rooms" Icon="@Icons.Material.Filled.MeetingRoom">Aulas</MudNavLink>
                <MudNavLink Href="/levels" Icon="@Icons.Material.Filled.Elevator">Niveles</MudNavLink>
                <MudNavLink Href="/scheduler" Icon="@Icons.Material.Filled.Schedule">Horarios</MudNavLink>
            </MudNavMenu>
        </MudDrawer>

        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
}
else
{
    @Body
}

@code {
    bool _drawerOpen = true;
    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    protected override void OnInitialized()
    {
        if (!Auth.IsAuthenticated && !Nav.Uri.Contains("/login"))
        {
            Nav.NavigateTo("/login");
        }
    }

    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = ThemeColors.WillowGreen,
            Secondary = ThemeColors.SoftSage,
            DrawerBackground = ThemeColors.Bone,
            TextPrimary = ThemeColors.TextoGris,
            ActionDefault = ThemeColors.TextoGris
        }
    };
}