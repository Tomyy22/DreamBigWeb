@page "/levels"
@using DreamBigManagement.Models
@using DreamBig.Core.Data.Repositories
@using DreamBig.Web.Constants
@using MudBlazor
@inject ILevelRepository LevelRepo
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<MudText Typo="Typo.h5" Class="mb-4" Style="@($"color:{ThemeColors.TextoGris};")">
    Gestión de Niveles
</MudText>

<MudDataGrid T="Level"
             @ref="_dataGrid"
             Items="@levels"
             ReadOnly="false"
             EditMode="DataGridEditMode.Form"
             CommittedItemChanges="SaveLevel"
             CanceledEditingItem="CancelEdit"
             Bordered="true"
             Striped="true">

    <ToolBarContent>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddLevel">
            Nuevo Nivel
        </MudButton>
    </ToolBarContent>

    <Columns>
        <PropertyColumn Property="x => x.level_name" Title="Nombre del Nivel">
            <EditTemplate>
                <MudTextField @bind-Value="context.Item.level_name"
                              Required="true"
                              RequiredError="El nombre es obligatorio"
                              Label="Nombre del Nivel" />
            </EditTemplate>
        </PropertyColumn>

        <PropertyColumn Property="x => x.price" Title="Precio" Format="C2">
            <EditTemplate>
                <MudNumericField @bind-Value="context.Item.price"
                                 Required="true"
                                 Min="1"
                                 RequiredError="El precio es obligatorio"
                                 Validation="@(new Func<double, string>(v => v > 0 ? null : "El precio debe ser mayor a 0"))"
                                 Label="Precio" />
            </EditTemplate>
        </PropertyColumn>

        <TemplateColumn Title="Acciones">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Color="Color.Primary"
                               OnClick="@(() => _dataGrid!.SetEditingItemAsync(context.Item))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               OnClick="@(() => DeleteLevel(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private List<Level> levels = new();
    private MudDataGrid<Level>? _dataGrid;

    protected override async Task OnInitializedAsync() => await LoadLevels();

    private async Task LoadLevels()
    {
        levels = await LevelRepo.GetAllLevelsAsync();
        StateHasChanged();
    }

    private async Task AddLevel()
    {
        var level = new Level();
        levels.Insert(0, level);
        await _dataGrid!.SetEditingItemAsync(level);
    }

    private async Task<DataGridEditFormAction> SaveLevel(Level level)
    {
        if (string.IsNullOrWhiteSpace(level.level_name) || level.price <= 0)
        {
            Snackbar.Add("Datos inválidos. Por favor, verifica el nombre y el precio.", Severity.Error);

            return DataGridEditFormAction.Close;
        }

        if (level.id_level == 0)
        {
            await LevelRepo.AddLevelAsync(level);
            Snackbar.Add("Nivel creado correctamente.", Severity.Success);
        }
        else
        {
            await LevelRepo.UpdateLevelAsync(level);
            Snackbar.Add("Nivel actualizado correctamente.", Severity.Success);
        }

        await LoadLevels();
        return DataGridEditFormAction.Close;
    }

    private async Task CancelEdit(Level level)
    {
        if (level.id_level == 0)
        {
            levels.Remove(level);
            await LoadLevels();
        }
    }

    private async Task DeleteLevel(Level level)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Confirmar",
            $"¿Está seguro de eliminar el nivel '{level.level_name}'?",
            yesText: "Borrar", cancelText: "Cancelar");

        if (result == true)
        {
            await LevelRepo.DeleteLevelAsync(level.id_level);
            Snackbar.Add("Nivel eliminado.", Severity.Success);
            await LoadLevels();
        }
    }
}